{
  "name": "openwrangler",
  "displayName": "Open Wrangler",
  "description": "An open-source dataframe wrangler for VS Code and Cursor with native Polars, DuckDB, and Pandas support.",
  "version": "0.3.0",
  "publisher": "Matt17BR",
  "license": "MIT",
  "preview": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Matt17BR/openwrangler.git"
  },
  "homepage": "https://github.com/Matt17BR/openwrangler#readme",
  "bugs": {
    "url": "https://github.com/Matt17BR/openwrangler/issues"
  },
  "keywords": [
    "dataframe",
    "data cleaning",
    "csv",
    "parquet",
    "jupyter",
    "polars",
    "duckdb",
    "pandas",
    "openwrangler",
    "vscode",
    "cursor"
  ],
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Data Science",
    "Visualization",
    "Notebooks"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Open Wrangler executes dataframe operations in the selected Python environment. Trust the workspace before opening data."
    },
    "virtualWorkspaces": {
      "supported": false,
      "description": "Desktop file and Python runtime access require a local or remote workspace file system."
    }
  },
  "main": "./dist/extension/activate.js",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "tsc -p tsconfig.extension.json",
    "build:test-extension": "tsc -p tsconfig.extension-test.json",
    "build:webview": "vite build",
    "typecheck": "tsc -p tsconfig.extension.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "lint": "eslint .",
    "lint:python": "node scripts/run-python.mjs -m ruff check python && node scripts/run-python.mjs -m ruff format --check python && node scripts/run-pyright.mjs python",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "docs:check": "node scripts/check-docs.mjs",
    "generate:reference": "node scripts/generate-reference.mjs",
    "reference:check": "node scripts/generate-reference.mjs --check",
    "generate:protocol": "node scripts/generate-protocol.mjs",
    "protocol:check": "node scripts/generate-protocol.mjs --check",
    "check": "npm run format:check && npm run lint && npm run lint:python && npm run protocol:check && npm run reference:check && npm run typecheck && npm run docs:check && npm run license:check",
    "watch": "npm-run-all --parallel watch:extension watch:webview",
    "watch:extension": "tsc -w -p tsconfig.extension.json",
    "watch:webview": "vite build --watch",
    "test": "npm run test:scripts && npm run test:ts && npm run test:python",
    "test:scripts": "node --test scripts/editor-acceptance.test.mjs scripts/editor-acceptance-evidence.test.mjs scripts/editor-acceptance-artifact.test.mjs scripts/packaged-editor-orchestration.test.mjs",
    "test:ts": "vitest run",
    "test:python": "node scripts/run-python.mjs -m pytest python/tests -q",
    "test:extension-host": "npm run build && npm run build:test-extension && node scripts/run-extension-tests.mjs",
    "test:packaged-editors": "npm run build:test-extension && npm run test:packaged-editors:run",
    "test:packaged-editors:run": "node scripts/run-packaged-editor-tests.mjs",
    "test:coverage": "npm run test:coverage:ts && npm run test:coverage:python",
    "test:coverage:ts": "vitest run --coverage",
    "test:coverage:python": "node scripts/run-python.mjs -m pytest python/tests -q --cov=openwrangler_runtime --cov-report=term --cov-report=xml:tmp/coverage/python.xml --cov-fail-under=78",
    "license:check": "node scripts/check-licenses.mjs",
    "capture:screenshots": "node scripts/capture-screenshots.mjs",
    "test:visual": "npm run build && node scripts/capture-screenshots.mjs --verify",
    "test:accessibility": "node scripts/test-webview-accessibility.mjs",
    "test:webview-acceptance": "npm run test:visual && npm run test:accessibility",
    "benchmark:runtime": "node scripts/run-python.mjs python/benchmarks/runtime_performance.py --strict --fixture-dir tmp/performance --json-out tmp/performance/report.json",
    "prepackage": "npm run clean && npm run build && npm run check && npm test",
    "package": "vsce package",
    "verify:vsix": "node scripts/verify-vsix.mjs"
  },
  "activationEvents": [
    "onCommand:openWrangler.openFile",
    "onCommand:openWrangler.openPath",
    "onCommand:openWrangler.launchDataViewer",
    "onCommand:openWrangler.openNotebookVariable",
    "onCommand:openWrangler.checkJupyterIntegration",
    "onCommand:openWrangler.changeRuntime",
    "onCommand:openWrangler.clearRuntime",
    "onCommand:openWrangler.installRuntimeDependencies",
    "onCommand:openWrangler.startOperation",
    "onCommand:openWrangler.applyStep",
    "onCommand:openWrangler.discardStep",
    "onCommand:openWrangler.editLatestStep",
    "onCommand:openWrangler.selectStep",
    "onCommand:openWrangler.undoStep",
    "onCommand:openWrangler.copyCode",
    "onCommand:openWrangler.exportCode",
    "onCommand:openWrangler.insertNotebookCode",
    "onCommand:openWrangler.exportData",
    "onCommand:openWrangler.openSourceFile",
    "onCommand:openWrangler.openWalkthrough",
    "onCommand:openWrangler.openSettings",
    "onCommand:openWrangler.reportIssue",
    "onCustomEditor:openWrangler.viewer",
    "onView:openWrangler.operations",
    "onView:openWrangler.summary",
    "onView:openWrangler.filters",
    "onView:openWrangler.cleaningSteps",
    "onView:openWrangler.codePreview",
    "onRenderer:openWrangler.renderer",
    "onNotebook:jupyter-notebook"
  ],
  "contributes": {
    "configurationDefaults": {
      "cursor.general.pinnedTitleActions": [
        "openWrangler.openFile"
      ]
    },
    "commands": [
      {
        "command": "openWrangler.openFile",
        "title": "Open in Open Wrangler",
        "icon": "$(open-preview)"
      },
      {
        "command": "openWrangler.openPath",
        "title": "Open Wrangler: Open File Path"
      },
      {
        "command": "openWrangler.launchDataViewer",
        "title": "Open Wrangler: Launch Selected Notebook Variable"
      },
      {
        "command": "openWrangler.openNotebookVariable",
        "title": "Open Wrangler: Open Notebook Variable"
      },
      {
        "command": "openWrangler.checkJupyterIntegration",
        "title": "Open Wrangler: Check Jupyter Integration"
      },
      {
        "command": "openWrangler.changeRuntime",
        "title": "Open Wrangler: Change Runtime"
      },
      {
        "command": "openWrangler.clearRuntime",
        "title": "Open Wrangler: Clear Runtime Override"
      },
      {
        "command": "openWrangler.installRuntimeDependencies",
        "title": "Open Wrangler: Install Runtime Dependencies"
      },
      {
        "command": "openWrangler.startOperation",
        "title": "Open Wrangler: Add Cleaning Step"
      },
      {
        "command": "openWrangler.applyStep",
        "title": "Open Wrangler: Apply Draft Step",
        "icon": "$(check)"
      },
      {
        "command": "openWrangler.discardStep",
        "title": "Open Wrangler: Discard Draft Step",
        "icon": "$(close)"
      },
      {
        "command": "openWrangler.editLatestStep",
        "title": "Open Wrangler: Edit Latest Step",
        "icon": "$(edit)"
      },
      {
        "command": "openWrangler.selectStep",
        "title": "Open Wrangler: Inspect Applied Step",
        "icon": "$(diff)"
      },
      {
        "command": "openWrangler.undoStep",
        "title": "Open Wrangler: Undo Latest Step",
        "icon": "$(discard)"
      },
      {
        "command": "openWrangler.copyCode",
        "title": "Open Wrangler: Copy Generated Code",
        "icon": "$(copy)"
      },
      {
        "command": "openWrangler.exportCode",
        "title": "Open Wrangler: Export Python Script",
        "icon": "$(save-as)"
      },
      {
        "command": "openWrangler.insertNotebookCode",
        "title": "Open Wrangler: Insert Function into Originating Notebook",
        "icon": "$(notebook)"
      },
      {
        "command": "openWrangler.exportData",
        "title": "Open Wrangler: Export Cleaned Data",
        "icon": "$(export)"
      },
      {
        "command": "openWrangler.openSourceFile",
        "title": "Open Wrangler: Open Source File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "openWrangler.openWalkthrough",
        "title": "Open Wrangler: Open Getting Started",
        "icon": "$(book)"
      },
      {
        "command": "openWrangler.openSettings",
        "title": "Open Wrangler: Open Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "openWrangler.reportIssue",
        "title": "Open Wrangler: Report Issue",
        "icon": "$(github)"
      }
    ],
    "keybindings": [
      {
        "command": "openWrangler.applyStep",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "activeCustomEditorId == openWrangler.viewer && openWrangler.hasDraft"
      },
      {
        "command": "openWrangler.discardStep",
        "key": "escape",
        "when": "activeCustomEditorId == openWrangler.viewer && openWrangler.hasDraft"
      },
      {
        "command": "openWrangler.editLatestStep",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "activeCustomEditorId == openWrangler.viewer && openWrangler.canChangePlan"
      },
      {
        "command": "openWrangler.undoStep",
        "key": "ctrl+alt+z",
        "mac": "cmd+alt+z",
        "when": "activeCustomEditorId == openWrangler.viewer && openWrangler.canChangePlan"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openWrangler",
          "title": "Open Wrangler",
          "icon": "media/activity-icon.svg"
        }
      ],
      "panel": [
        {
          "id": "openWranglerCode",
          "title": "Open Wrangler Code",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "openWrangler": [
        {
          "id": "openWrangler.operations",
          "name": "Operations"
        },
        {
          "id": "openWrangler.summary",
          "name": "Summary"
        },
        {
          "id": "openWrangler.filters",
          "name": "Filters / Sorts"
        },
        {
          "id": "openWrangler.cleaningSteps",
          "name": "Cleaning Steps"
        }
      ],
      "openWranglerCode": [
        {
          "type": "webview",
          "id": "openWrangler.codePreview",
          "name": "Code Preview"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "openWrangler.operations",
        "contents": "Open a data file or notebook dataframe to start exploring.\n[Open a data file](command:openWrangler.openPath)"
      }
    ],
    "jupyterVariableViewers": [
      {
        "command": "openWrangler.launchDataViewer",
        "title": "Open in Open Wrangler",
        "dataTypes": [
          "DataFrame",
          "Series",
          "pandas.core.frame.DataFrame",
          "pandas.DataFrame",
          "pandas.core.series.Series",
          "pandas.Series",
          "polars.dataframe.frame.DataFrame",
          "polars.series.series.Series"
        ]
      }
    ],
    "customEditors": [
      {
        "viewType": "openWrangler.viewer",
        "displayName": "Open Wrangler",
        "selector": [
          {
            "filenamePattern": "*.csv"
          },
          {
            "filenamePattern": "*.tsv"
          },
          {
            "filenamePattern": "*.parquet"
          },
          {
            "filenamePattern": "*.jsonl"
          },
          {
            "filenamePattern": "*.xlsx"
          },
          {
            "filenamePattern": "*.xls"
          }
        ],
        "priority": "option"
      }
    ],
    "notebookRenderer": [
      {
        "id": "openWrangler.renderer",
        "displayName": "Open Wrangler Renderer",
        "entrypoint": "./media/notebookRenderer.js",
        "requiresMessaging": "optional",
        "mimeTypes": [
          "application/vnd.openwrangler.viewer.v2+json"
        ]
      }
    ],
    "walkthroughs": [
      {
        "id": "gettingStarted",
        "title": "Get started with Open Wrangler",
        "description": "Explore, clean, and export tabular data with Pandas, Polars, or DuckDB file sessions and Pandas or Polars notebook sessions without modifying the source.",
        "steps": [
          {
            "id": "openData",
            "title": "Open a data source",
            "description": "Use [Open File Path](command:openWrangler.openPath) for CSV, TSV, Parquet, JSONL, or Excel, or launch Open Wrangler from a notebook dataframe."
          },
          {
            "id": "explore",
            "title": "Explore without changing data",
            "description": "Use column insights, filters, sorts, search, and the virtual grid. Viewing state remains separate from cleaning steps."
          },
          {
            "id": "clean",
            "title": "Preview a cleaning step",
            "description": "Choose [Add Cleaning Step](command:openWrangler.startOperation), inspect its diff and generated code, then apply or discard it."
          },
          {
            "id": "export",
            "title": "Export explicitly",
            "description": "Copy or save generated code, insert it into the originating notebook, or export cleaned data to a new CSV or Parquet file."
          }
        ]
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "openWrangler.openFile",
          "when": "!explorerResourceIsFolder && resourceScheme =~ /^(file|vscode-remote)$/ && resourceExtname =~ /\\.(csv|tsv|parquet|jsonl|xlsx|xls)$/i",
          "group": "navigation@50"
        }
      ],
      "editor/title": [
        {
          "command": "openWrangler.openFile",
          "when": "resourceScheme =~ /^(file|vscode-remote)$/ && resourceExtname =~ /\\.(csv|tsv|parquet|jsonl|xlsx|xls)$/i && (!activeCustomEditorId || activeCustomEditorId != openWrangler.viewer)",
          "group": "navigation@1"
        }
      ],
      "editor/title/context": [
        {
          "command": "openWrangler.openFile",
          "when": "resourceScheme =~ /^(file|vscode-remote)$/ && resourceExtname =~ /\\.(csv|tsv|parquet|jsonl|xlsx|xls)$/i && (!activeCustomEditorId || activeCustomEditorId != openWrangler.viewer)",
          "group": "navigation@50"
        }
      ],
      "commandPalette": [
        {
          "command": "openWrangler.launchDataViewer",
          "when": "false"
        }
      ],
      "notebook/title": [
        {
          "command": "openWrangler.openNotebookVariable",
          "when": "notebookKernel =~ /^ms-toolsai.jupyter\\// && notebookType == jupyter-notebook",
          "group": "navigation@50"
        }
      ],
      "view/title": [
        {
          "command": "openWrangler.copyCode",
          "when": "view == openWrangler.codePreview",
          "group": "navigation@10"
        },
        {
          "command": "openWrangler.exportCode",
          "when": "view == openWrangler.codePreview",
          "group": "navigation@11"
        },
        {
          "command": "openWrangler.insertNotebookCode",
          "when": "view == openWrangler.codePreview",
          "group": "navigation@12"
        },
        {
          "command": "openWrangler.openSourceFile",
          "when": "viewContainer == openWrangler",
          "group": "navigation@80"
        },
        {
          "command": "openWrangler.openWalkthrough",
          "when": "viewContainer == openWrangler",
          "group": "navigation@89"
        },
        {
          "command": "openWrangler.openSettings",
          "when": "viewContainer == openWrangler",
          "group": "navigation@90"
        },
        {
          "command": "openWrangler.reportIssue",
          "when": "viewContainer == openWrangler",
          "group": "navigation@91"
        }
      ],
      "view/item/context": [
        {
          "command": "openWrangler.editLatestStep",
          "when": "view == openWrangler.cleaningSteps && viewItem == openWrangler.latestCleaningStep && openWrangler.canChangePlan",
          "group": "inline@10"
        }
      ]
    },
    "configuration": {
      "title": "Open Wrangler",
      "properties": {
        "openWrangler.defaultBackend": {
          "type": "string",
          "enum": [
            "auto",
            "polars",
            "duckdb",
            "pandas"
          ],
          "default": "auto",
          "description": "Default backend for file-backed sessions. Auto prefers Polars, then DuckDB, and falls back to Pandas when required."
        },
        "openWrangler.fileStartMode": {
          "type": "string",
          "enum": [
            "editing",
            "viewing"
          ],
          "default": "editing",
          "description": "Initial mode for file-backed sessions. Editing remains non-destructive until an explicit export."
        },
        "openWrangler.notebookStartMode": {
          "type": "string",
          "enum": [
            "viewing",
            "editing"
          ],
          "default": "viewing",
          "description": "Initial mode for notebook dataframe sessions."
        },
        "openWrangler.enabledFileTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "csv",
              "tsv",
              "parquet",
              "jsonl",
              "xlsx",
              "xls"
            ]
          },
          "uniqueItems": true,
          "default": [
            "csv",
            "tsv",
            "parquet",
            "jsonl",
            "xlsx",
            "xls"
          ],
          "description": "File types accepted by Open Wrangler launch commands and offered by its file picker. Explicit Reopen Editor With selection remains available."
        },
        "openWrangler.insightsOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Show progressive per-column insights when a grid opens."
        },
        "openWrangler.filterMode": {
          "type": "string",
          "enum": [
            "basic",
            "advanced"
          ],
          "default": "basic",
          "description": "Default filter builder. Advanced mode exposes AND/OR condition composition."
        },
        "openWrangler.defaultColumnWidth": {
          "type": "number",
          "default": 190,
          "minimum": 80,
          "maximum": 640,
          "description": "Initial grid column width in CSS pixels."
        },
        "openWrangler.fetchBlockSize": {
          "type": "number",
          "default": 200,
          "minimum": 25,
          "maximum": 2000,
          "description": "Number of rows fetched for each virtual grid block."
        },
        "openWrangler.fetchColumnBlockSize": {
          "type": "number",
          "default": 16,
          "minimum": 1,
          "maximum": 256,
          "description": "Number of dataframe columns fetched for each horizontal grid block."
        },
        "openWrangler.panelRevealBehavior": {
          "type": "string",
          "enum": [
            "onDraft",
            "always",
            "never"
          ],
          "default": "onDraft",
          "description": "When to reveal the bottom-panel Code Preview."
        },
        "openWrangler.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Optional Python 3.10-3.14 executable override. When empty, Open Wrangler uses the selected Python extension environment, then a system interpreter."
        },
        "openWrangler.sessionOpenTimeoutMs": {
          "type": "number",
          "default": 60000,
          "minimum": 1000,
          "maximum": 600000,
          "description": "Maximum duration for opening a dataframe session, including cold engine and notebook-kernel initialization."
        },
        "openWrangler.requestTimeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "maximum": 600000,
          "description": "Maximum duration for runtime requests other than session opening before recovery restarts and replays the session."
        }
      }
    }
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lezer/highlight": "^1.2.3",
    "@vscode/codicons": "^0.0.45",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.105.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "@vscode/jupyter-extension": "^1.1.1",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.1",
    "axe-core": "^4.12.1",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.3.0",
    "jsdom": "^29.1.1",
    "json-schema-to-typescript": "^15.0.4",
    "npm-run-all": "^4.1.5",
    "pixelmatch": "^7.2.0",
    "playwright-core": "^1.61.1",
    "pngjs": "^7.0.0",
    "prettier": "^3.6.2",
    "pyright": "^1.1.405",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
