{
  "name": "data-explorer",
  "displayName": "Data Explorer",
  "description": "A visualization-first dataframe explorer for VS Code-compatible editors with native Polars and Pandas support.",
  "version": "0.2.0-alpha.1",
  "publisher": "Matt17BR",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Matt17BR/data-explorer.git"
  },
  "homepage": "https://github.com/Matt17BR/data-explorer#readme",
  "bugs": {
    "url": "https://github.com/Matt17BR/data-explorer/issues"
  },
  "keywords": [
    "dataframe",
    "polars",
    "pandas",
    "data-explorer",
    "vscode",
    "cursor"
  ],
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Data Science",
    "Visualization"
  ],
  "icon": "media/icon.png",
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Data Explorer executes dataframe operations in the selected Python environment. Trust the workspace before opening data."
    },
    "virtualWorkspaces": {
      "supported": false,
      "description": "Desktop file and Python runtime access require a local or remote workspace file system."
    }
  },
  "main": "./dist/extension/activate.js",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "tsc -p tsconfig.extension.json",
    "build:test-extension": "tsc -p tsconfig.extension-test.json",
    "build:webview": "vite build",
    "typecheck": "tsc -p tsconfig.extension.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "lint": "eslint .",
    "lint:python": "node scripts/run-python.mjs -m ruff check python && node scripts/run-python.mjs -m ruff format --check python && node scripts/run-pyright.mjs python",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "docs:check": "node scripts/check-docs.mjs",
    "generate:reference": "node scripts/generate-reference.mjs",
    "reference:check": "node scripts/generate-reference.mjs --check",
    "generate:protocol": "node scripts/generate-protocol.mjs",
    "protocol:check": "node scripts/generate-protocol.mjs --check",
    "check": "npm run format:check && npm run lint && npm run lint:python && npm run protocol:check && npm run reference:check && npm run typecheck && npm run docs:check && npm run license:check",
    "watch": "npm-run-all --parallel watch:extension watch:webview",
    "watch:extension": "tsc -w -p tsconfig.extension.json",
    "watch:webview": "vite build --watch",
    "test": "npm run test:ts && npm run test:python",
    "test:ts": "vitest run",
    "test:python": "node scripts/run-python.mjs -m pytest python/tests -q",
    "test:extension-host": "npm run build && npm run build:test-extension && node scripts/run-extension-tests.mjs",
    "test:packaged-editors": "npm run build:test-extension && node scripts/run-packaged-editor-tests.mjs",
    "test:coverage": "npm run test:coverage:ts && npm run test:coverage:python",
    "test:coverage:ts": "vitest run --coverage",
    "test:coverage:python": "node scripts/run-python.mjs -m pytest python/tests -q --cov=data_wrangler_runtime --cov-report=term --cov-report=xml:tmp/coverage/python.xml --cov-fail-under=78",
    "license:check": "node scripts/check-licenses.mjs",
    "capture:screenshots": "node scripts/capture-screenshots.mjs",
    "test:visual": "npm run build && node scripts/capture-screenshots.mjs --verify",
    "test:accessibility": "node scripts/test-webview-accessibility.mjs",
    "test:webview-acceptance": "npm run test:visual && npm run test:accessibility",
    "benchmark:runtime": "node scripts/run-python.mjs python/benchmarks/runtime_performance.py --strict --fixture-dir tmp/performance --json-out tmp/performance/report.json",
    "prepackage": "npm run clean && npm run build && npm run check && npm test",
    "package": "vsce package",
    "verify:vsix": "node scripts/verify-vsix.mjs"
  },
  "activationEvents": [
    "onCommand:dataExplorer.openFile",
    "onCommand:dataExplorer.openPath",
    "onCommand:dataExplorer.launchDataViewer",
    "onCommand:dataExplorer.openNotebookVariable",
    "onCommand:dataExplorer.checkJupyterIntegration",
    "onCommand:dataExplorer.changeRuntime",
    "onCommand:dataExplorer.clearRuntime",
    "onCommand:dataExplorer.installRuntimeDependencies",
    "onCommand:dataExplorer.startOperation",
    "onCommand:dataExplorer.applyStep",
    "onCommand:dataExplorer.discardStep",
    "onCommand:dataExplorer.editLatestStep",
    "onCommand:dataExplorer.undoStep",
    "onCommand:dataExplorer.copyCode",
    "onCommand:dataExplorer.exportCode",
    "onCommand:dataExplorer.insertNotebookCode",
    "onCommand:dataExplorer.exportData",
    "onCommand:dataExplorer.openSourceFile",
    "onCommand:dataExplorer.openWalkthrough",
    "onCommand:dataExplorer.openSettings",
    "onCommand:dataExplorer.reportIssue",
    "onCustomEditor:dataExplorer.viewer",
    "onView:dataExplorer.operations",
    "onView:dataExplorer.summary",
    "onView:dataExplorer.filters",
    "onView:dataExplorer.cleaningSteps",
    "onView:dataExplorer.codePreview",
    "onNotebook:jupyter-notebook"
  ],
  "contributes": {
    "commands": [
      {
        "command": "dataExplorer.openFile",
        "title": "Data Explorer: Open Current File"
      },
      {
        "command": "dataExplorer.openPath",
        "title": "Data Explorer: Open File Path"
      },
      {
        "command": "dataExplorer.launchDataViewer",
        "title": "Open in Data Explorer"
      },
      {
        "command": "dataExplorer.openNotebookVariable",
        "title": "Data Explorer: Open Notebook Variable"
      },
      {
        "command": "dataExplorer.checkJupyterIntegration",
        "title": "Data Explorer: Check Jupyter Integration"
      },
      {
        "command": "dataExplorer.changeRuntime",
        "title": "Data Explorer: Change Runtime"
      },
      {
        "command": "dataExplorer.clearRuntime",
        "title": "Data Explorer: Clear Runtime Override"
      },
      {
        "command": "dataExplorer.installRuntimeDependencies",
        "title": "Data Explorer: Install Runtime Dependencies"
      },
      {
        "command": "dataExplorer.startOperation",
        "title": "Data Explorer: Add Cleaning Step"
      },
      {
        "command": "dataExplorer.applyStep",
        "title": "Data Explorer: Apply Draft Step",
        "icon": "$(check)"
      },
      {
        "command": "dataExplorer.discardStep",
        "title": "Data Explorer: Discard Draft Step",
        "icon": "$(close)"
      },
      {
        "command": "dataExplorer.editLatestStep",
        "title": "Data Explorer: Edit Latest Step",
        "icon": "$(edit)"
      },
      {
        "command": "dataExplorer.undoStep",
        "title": "Data Explorer: Undo Latest Step",
        "icon": "$(discard)"
      },
      {
        "command": "dataExplorer.copyCode",
        "title": "Data Explorer: Copy Generated Code",
        "icon": "$(copy)"
      },
      {
        "command": "dataExplorer.exportCode",
        "title": "Data Explorer: Export Python Script",
        "icon": "$(save-as)"
      },
      {
        "command": "dataExplorer.insertNotebookCode",
        "title": "Data Explorer: Insert Function into Originating Notebook",
        "icon": "$(notebook)"
      },
      {
        "command": "dataExplorer.exportData",
        "title": "Data Explorer: Export Cleaned Data",
        "icon": "$(export)"
      },
      {
        "command": "dataExplorer.openSourceFile",
        "title": "Data Explorer: Open Source File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "dataExplorer.openWalkthrough",
        "title": "Data Explorer: Open Getting Started",
        "icon": "$(book)"
      },
      {
        "command": "dataExplorer.openSettings",
        "title": "Data Explorer: Open Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "dataExplorer.reportIssue",
        "title": "Data Explorer: Report Issue",
        "icon": "$(github)"
      }
    ],
    "keybindings": [
      {
        "command": "dataExplorer.applyStep",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "activeCustomEditor == dataExplorer.viewer && dataExplorer.hasDraft"
      },
      {
        "command": "dataExplorer.discardStep",
        "key": "escape",
        "when": "activeCustomEditor == dataExplorer.viewer && dataExplorer.hasDraft"
      },
      {
        "command": "dataExplorer.editLatestStep",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "activeCustomEditor == dataExplorer.viewer && dataExplorer.canChangePlan"
      },
      {
        "command": "dataExplorer.undoStep",
        "key": "ctrl+alt+z",
        "mac": "cmd+alt+z",
        "when": "activeCustomEditor == dataExplorer.viewer && dataExplorer.canChangePlan"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dataExplorer",
          "title": "Data Explorer",
          "icon": "media/activity-icon.svg"
        }
      ],
      "panel": [
        {
          "id": "dataExplorerCode",
          "title": "Data Explorer Code",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "dataExplorer": [
        {
          "id": "dataExplorer.operations",
          "name": "Operations"
        },
        {
          "id": "dataExplorer.summary",
          "name": "Summary"
        },
        {
          "id": "dataExplorer.filters",
          "name": "Filters / Sorts"
        },
        {
          "id": "dataExplorer.cleaningSteps",
          "name": "Cleaning Steps"
        }
      ],
      "dataExplorerCode": [
        {
          "type": "webview",
          "id": "dataExplorer.codePreview",
          "name": "Code Preview"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "dataExplorer.operations",
        "contents": "Open a data file or notebook dataframe to start exploring.\n[Open a data file](command:dataExplorer.openPath)"
      }
    ],
    "jupyterVariableViewers": [
      {
        "command": "dataExplorer.launchDataViewer",
        "title": "Open in Data Explorer",
        "dataTypes": [
          "DataFrame",
          "Series",
          "pandas.core.frame.DataFrame",
          "pandas.DataFrame",
          "pandas.core.series.Series",
          "pandas.Series",
          "polars.dataframe.frame.DataFrame",
          "polars.series.series.Series"
        ]
      }
    ],
    "customEditors": [
      {
        "viewType": "dataExplorer.viewer",
        "displayName": "Data Explorer",
        "selector": [
          {
            "filenamePattern": "*.csv"
          },
          {
            "filenamePattern": "*.tsv"
          },
          {
            "filenamePattern": "*.parquet"
          },
          {
            "filenamePattern": "*.jsonl"
          },
          {
            "filenamePattern": "*.xlsx"
          },
          {
            "filenamePattern": "*.xls"
          }
        ],
        "priority": "option"
      }
    ],
    "notebookRenderer": [
      {
        "id": "dataExplorer.renderer",
        "displayName": "Data Explorer Renderer",
        "entrypoint": "./media/notebookRenderer.js",
        "requiresMessaging": "always",
        "mimeTypes": [
          "application/vnd.data-explorer.viewer.v1+json",
          "application/vnd.data-explorer.viewer.v2+json"
        ]
      }
    ],
    "walkthroughs": [
      {
        "id": "gettingStarted",
        "title": "Get started with Data Explorer",
        "description": "Explore, clean, and export Pandas or Polars dataframes without modifying the source.",
        "steps": [
          {
            "id": "openData",
            "title": "Open a data source",
            "description": "Use [Open File Path](command:dataExplorer.openPath) for CSV, TSV, Parquet, JSONL, or Excel, or launch Data Explorer from a notebook dataframe."
          },
          {
            "id": "explore",
            "title": "Explore without changing data",
            "description": "Use column insights, filters, sorts, search, and the virtual grid. Viewing state remains separate from cleaning steps."
          },
          {
            "id": "clean",
            "title": "Preview a cleaning step",
            "description": "Choose [Add Cleaning Step](command:dataExplorer.startOperation), inspect its diff and generated code, then apply or discard it."
          },
          {
            "id": "export",
            "title": "Export explicitly",
            "description": "Copy or save generated code, insert it into the originating notebook, or export cleaned data to a new CSV or Parquet file."
          }
        ]
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "dataExplorer.openFile",
          "when": "resourceExtname =~ /\\.(csv|tsv|parquet|jsonl|xlsx|xls)$/",
          "group": "navigation@50"
        }
      ],
      "notebook/title": [
        {
          "command": "dataExplorer.openNotebookVariable",
          "when": "notebookKernel =~ /^ms-toolsai.jupyter\\// && notebookType == jupyter-notebook",
          "group": "navigation@50"
        }
      ],
      "view/title": [
        {
          "command": "dataExplorer.copyCode",
          "when": "view == dataExplorer.codePreview",
          "group": "navigation@10"
        },
        {
          "command": "dataExplorer.exportCode",
          "when": "view == dataExplorer.codePreview",
          "group": "navigation@11"
        },
        {
          "command": "dataExplorer.insertNotebookCode",
          "when": "view == dataExplorer.codePreview",
          "group": "navigation@12"
        },
        {
          "command": "dataExplorer.openSourceFile",
          "when": "viewContainer == dataExplorer",
          "group": "navigation@80"
        },
        {
          "command": "dataExplorer.openWalkthrough",
          "when": "viewContainer == dataExplorer",
          "group": "navigation@89"
        },
        {
          "command": "dataExplorer.openSettings",
          "when": "viewContainer == dataExplorer",
          "group": "navigation@90"
        },
        {
          "command": "dataExplorer.reportIssue",
          "when": "viewContainer == dataExplorer",
          "group": "navigation@91"
        }
      ]
    },
    "configuration": {
      "title": "Data Explorer",
      "properties": {
        "dataExplorer.defaultBackend": {
          "type": "string",
          "enum": [
            "auto",
            "polars",
            "pandas"
          ],
          "default": "auto",
          "description": "Default backend for file-backed sessions. Auto prefers Polars and falls back to Pandas when required."
        },
        "dataExplorer.fileStartMode": {
          "type": "string",
          "enum": [
            "editing",
            "viewing"
          ],
          "default": "editing",
          "description": "Initial mode for file-backed sessions. Editing remains non-destructive until an explicit export."
        },
        "dataExplorer.notebookStartMode": {
          "type": "string",
          "enum": [
            "viewing",
            "editing"
          ],
          "default": "viewing",
          "description": "Initial mode for notebook dataframe sessions."
        },
        "dataExplorer.enabledFileTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "csv",
              "tsv",
              "parquet",
              "jsonl",
              "xlsx",
              "xls"
            ]
          },
          "uniqueItems": true,
          "default": [
            "csv",
            "tsv",
            "parquet",
            "jsonl",
            "xlsx",
            "xls"
          ],
          "description": "File types offered by Data Explorer file pickers. Explicit custom-editor selection remains available."
        },
        "dataExplorer.insightsOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Show progressive per-column insights when a grid opens."
        },
        "dataExplorer.filterMode": {
          "type": "string",
          "enum": [
            "basic",
            "advanced"
          ],
          "default": "basic",
          "description": "Default filter builder. Advanced mode exposes AND/OR condition composition."
        },
        "dataExplorer.defaultColumnWidth": {
          "type": "number",
          "default": 190,
          "minimum": 80,
          "maximum": 640,
          "description": "Initial grid column width in CSS pixels."
        },
        "dataExplorer.fetchBlockSize": {
          "type": "number",
          "default": 200,
          "minimum": 25,
          "maximum": 2000,
          "description": "Number of rows fetched for each virtual grid block."
        },
        "dataExplorer.pageSize": {
          "type": "number",
          "default": 200,
          "minimum": 25,
          "maximum": 2000,
          "description": "Deprecated alias for fetchBlockSize."
        },
        "dataExplorer.panelRevealBehavior": {
          "type": "string",
          "enum": [
            "onDraft",
            "always",
            "never"
          ],
          "default": "onDraft",
          "description": "When to reveal the bottom-panel Code Preview."
        },
        "dataExplorer.renderer.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Data Explorer notebook MIME renderer messaging. Saved v1 and v2 outputs remain readable."
        },
        "dataExplorer.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Optional Python 3.10-3.14 executable override. When empty, Data Explorer uses the selected Python extension environment, then a system interpreter."
        },
        "dataExplorer.requestTimeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "maximum": 600000,
          "description": "Maximum runtime request duration before recovery restarts and replays the session."
        }
      }
    }
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lezer/highlight": "^1.2.3",
    "@vscode/codicons": "^0.0.45",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.105.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.1",
    "axe-core": "^4.12.1",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "json-schema-to-typescript": "^15.0.4",
    "npm-run-all": "^4.1.5",
    "pixelmatch": "^7.2.0",
    "playwright-core": "^1.61.1",
    "pngjs": "^7.0.0",
    "prettier": "^3.6.2",
    "pyright": "^1.1.405",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
